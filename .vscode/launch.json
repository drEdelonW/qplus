{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach: 32 gdbserver (quake.x11)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/GNU_MAKE/run_env/quakeX11", // локальный путь к символам
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb-multiarch", // <— установите: sudo apt-get install gdb-multiarch
      // "miDebuggerPath": "/usr/bin/gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtEntry": false,
      "environment": [
        {
          "name": "DISPLAY",
          "value": ":1"
        }
      ],
      "sourceFileMap": {
        "/home/edelon/SelfLab/quake": "${workspaceFolder}" // подстрой под свои пути
      },
      "setupCommands": [
        {
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        { "text": "set pagination off" },
        { "text": "set breakpoint pending on" },
        { "text": "set architecture arm" },
        { "text": "set endian little" },
        { "text": "set sysroot target:" },
        { "text": "set follow-fork-mode child" },
        { "text": "set detach-on-fork off" },
        { "text": "catch exec" }
      ]
    },{
