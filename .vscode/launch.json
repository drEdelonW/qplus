{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach: gdbserver (quake.x11)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/GNU_MAKE/run_env/quake",          // локальный путь к символам
      "args": [],                                     // арг-ты НЕ нужны: их дал gdbserver
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtEntry": false,
      "environment": [ { "name": "DISPLAY", "value": ":1" } ],
      "sourceFileMap": {
        "/home/edelon/SelfLab/Quake": "${workspaceFolder}"  // подстрой под свои пути
      },
      "setupCommands": [
        { "description": "Pretty printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ]
    }
  ]
}
