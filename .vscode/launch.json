{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach: gdbserver (quake.x11)",
      "type": "cppdbg",
      "request": "launch",
      // "program": "${workspaceFolder}/GNU_MAKE/run_env/quake",          // локальный путь к символам
      "program": "${workspaceFolder}/GNU_MAKE/run_env/quakeX11", // локальный путь к символам
      "args": [], // арг-ты НЕ нужны: их дал gdbserver
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      // "miDebuggerPath": "gdb",
      "miDebuggerPath": "/usr/bin/gdb-multiarch", // <— установите: sudo apt-get install gdb-multiarch
      // "miDebuggerPath": "/usr/bin/gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtEntry": false,
      "environment": [
        {
          "name": "DISPLAY",
          "value": ":1"
        }
      ],
      "sourceFileMap": {
        // "/home/edelon/SelfLab/Quake": "${workspaceFolder}"  // подстрой под свои пути
        "/home/edelon/SelfLab/quake": "${workspaceFolder}" // подстрой под свои пути
      },
      // "setupCommands": [
      //   {
      //     "description": "Pretty printing",
      //     "text": "-enable-pretty-printing",
      //     "ignoreFailures": true
      //   }
      // ]
      "setupCommands": [
        {
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        { "text": "set pagination off" },
        { "text": "set breakpoint pending on" },
        {
          // "text": "set architecture arm"
          "text": "set architecture aarch64"
        },
        { "text": "set endian little" },
        { "text": "set sysroot target:" },
        { "text": "set follow-fork-mode child" },
        { "text": "set detach-on-fork off" },
        { "text": "catch exec" }
      ]
    }
  ]
}